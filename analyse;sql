 Projet : Analyse des ventes Supermarché
-- Auteur : Sylvia Kwambo 
-- Fichier : analyse.sql
-- Description : Réponses aux 10 questions d'analyse des données.

 QUESTION 1 : Produits les plus vendus

SELECT nom_produit,SUM(Quantite) AS quantite_totale
FROM facture 
GROUP BY nom_produit
ORDER BY quantite_totale DESC;

QUESTION 2 : Catégories les plus rentables

SELECT Catégories,SUM(Quantité * prix_unitaire) AS Revenus
FROM facture 
GROUP BY Catégories
ORDER BY Revenus DESC;

QUESTION 3 : Villes avec le plus de ventes

SELECT ville,SUM(Quantite * prix_unitaire) AS revenue
FROM facture 
GROUP BY ville 
ORDER BY revenue DESC;

QUESTION 4 : Mois avec le plus des ventes 

SELECT MONTH(Date) AS Mois,SUM(prix_unitaire * Quantite) AS Total_Ventes
FROM facture 
GROUP BY Mois
ORDER BY Mois;

QUESTION 5 : Méthodes de paiement le plus utilisées

Select méthode_payement,count(*) As total 
From facture
GROUP BY méthode_payement
ORDER BY total DESC;

QUESTION 6 : nom,genre,âge du client qui a le plus dépensé  

SELECT nom, âge,genre,SUM(Quantite * prix_unitaire) AS Total_Revenus
FROM facture 
joint client
using(facture_id)
GROUP BY nom, âge,genre
ORDER BY Total_Revenus DESC
LIMIT 5;

QUESTION 7 : moyenne des dépenses par genre 

SELECT genre ,AVG(Quantite) AS moyenne_dépenses 
FROM facture
joint client
using(facture_id) 
GROUP BY genre
ORDER BY dépenses DESC;

QUESTION 8 : Produits les plus populaires par tranche d’âge

SELECT nom_produit,SUM(Quantite * prix_unitaire) AS Total_Achat
FROM facture
JOIN client 
using(facture_id)
GROUP BY nom_produit
ORDER BY Total_Achat DESC
limite 5;

QUESTION 9 : Nombre de clients par ville

SELECT villes,count(distinct client_id) AS nombre_clients
FROM facture
joint client
using(facture_id)
GROUP BY villes
ORDER BY nombre_clients DESC
LIMIT 5;

